# ==========================================
# Application
# ==========================================
APP_NAME=Trader Intelligence AI Copilot
APP_VERSION=0.1.0

ENVIRONMENT=development
DEBUG=True

# ==========================================
# Database
# ==========================================
DATABASE_PROVIDER=postgres
DATABASE_URL=postgresql+psycopg2://trader:trader@localhost:55432/trader_intelligence

DATABASE_ECHO=False
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ==========================================
# LLM
# ==========================================
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# ==========================================
# Embeddings
# ==========================================
EMBEDDING_PROVIDER=gemini

# ==========================================
# Vector Store
# ==========================================
VECTORSTORE_PROVIDER=chroma

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=INFO

# ==========================================
# Security (replace in every real environment)
# ==========================================
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Development bootstrap (opt in explicitly)
ALLOW_DEVELOPMENT_BOOTSTRAP=false
BOOTSTRAP_SAMPLE_TRADER=false
BOOTSTRAP_TRADER_PASSWORD=
BOOTSTRAP_ANALYST_PASSWORD=
BOOTSTRAP_ADMIN_PASSWORD=
